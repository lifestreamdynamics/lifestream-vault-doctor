{
  "name": "@lifestreamdynamics/doctor",
  "version": "1.0.3",
  "description": "Crash reporting SDK for Lifestream Vault — uploads reports as Markdown documents",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react-native": {
      "types": "./dist/adapters/react-native/index.d.ts",
      "import": "./dist/adapters/react-native/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/__tests__",
    "react-native.js",
    "react-native.d.ts",
    "README.md"
  ],
  "keywords": [
    "lifestream",
    "vault",
    "crash-reporting",
    "error-tracking",
    "markdown",
    "typescript"
  ],
  "author": "Lifestream Dynamics <eric@lifestreamdynamics.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifestreamdynamics/lifestream-vault.git",
    "directory": "packages/doctor"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "@react-native-async-storage/async-storage": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "~19.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
